<article class="page-article">
  <%
    var avatarSrc  = (theme.about && theme.about.avatar) || page.avatar || '';
    var aboutName  = (theme.about && theme.about.name)   || config.author || page.title || '关于';
    var aboutBio   = (theme.about && theme.about.bio)    || '';
    var links      = (theme.about && theme.about.links)  || {};
    var hasLinks   = links.github || links.email || links.twitter || links.website;
  %>

  <div class="about-profile">
    <% if (avatarSrc) { %>
      <div class="about-avatar-wrap">
        <img src="<%- url_for(avatarSrc) %>" alt="<%= aboutName %>" class="about-avatar">
      </div>
    <% } %>

    <div class="about-info">
      <h1 class="about-name"><%= aboutName %></h1>
      <% if (aboutBio) { %>
        <p class="about-bio"><%= aboutBio %></p>
      <% } %>

      <% if (hasLinks) { %>
        <div class="about-links">
          <% if (links.github) { %>
            <a href="<%= links.github %>" class="about-link" target="_blank" rel="noopener noreferrer">
              <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M12 0C5.37 0 0 5.37 0 12c0 5.31 3.435 9.795 8.205 11.385.6.105.825-.255.825-.57 0-.285-.015-1.23-.015-2.235-3.015.555-3.795-.735-4.035-1.41-.135-.345-.72-1.41-1.23-1.695-.42-.225-1.02-.78-.015-.795.945-.015 1.62.87 1.845 1.23 1.08 1.815 2.805 1.305 3.495.99.105-.78.42-1.305.765-1.605-2.67-.3-5.46-1.335-5.46-5.925 0-1.305.465-2.385 1.23-3.225-.12-.3-.54-1.53.12-3.18 0 0 1.005-.315 3.3 1.23.96-.27 1.98-.405 3-.405s2.04.135 3 .405c2.295-1.56 3.3-1.23 3.3-1.23.66 1.65.24 2.88.12 3.18.765.84 1.23 1.905 1.23 3.225 0 4.605-2.805 5.625-5.475 5.925.435.375.81 1.095.81 2.22 0 1.605-.015 2.895-.015 3.3 0 .315.225.69.825.57A12.02 12.02 0 0 0 24 12c0-6.63-5.37-12-12-12z"/></svg>
              GitHub
            </a>
          <% } %>
          <% if (links.email) { %>
            <a href="mailto:<%= links.email %>" class="about-link">
              <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><rect x="2" y="4" width="20" height="16" rx="2"/><path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7"/></svg>
              Email
            </a>
          <% } %>
          <% if (links.twitter) { %>
            <a href="<%= links.twitter %>" class="about-link" target="_blank" rel="noopener noreferrer">
              <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-4.714-6.231-5.401 6.231H2.744l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"/></svg>
              Twitter / X
            </a>
          <% } %>
          <% if (links.website) { %>
            <a href="<%= links.website %>" class="about-link" target="_blank" rel="noopener noreferrer">
              <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><circle cx="12" cy="12" r="10"/><path d="M2 12h20M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z"/></svg>
              网站
            </a>
          <% } %>
        </div>
      <% } %>
    </div>
  </div>

  <% if (page.content && page.content.trim()) { %>
    <div class="post-content about-content">
      <%- page.content %>
    </div>
  <% } %>

  <%- partial('_partial/comments') %>
</article>
