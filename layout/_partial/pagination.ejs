<% if (page.total > 1) { %>
<nav class="pagination" aria-label="分页">
  <% if (page.prev) { %>
    <a href="<%- url_for(page.prev_link) %>" class="page-btn page-prev" aria-label="上一页">
      <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="15 18 9 12 15 6"/></svg>
      上一页
    </a>
  <% } %>

  <div class="page-numbers">
    <% var start = Math.max(1, page.current - 2); %>
    <% var end   = Math.min(page.total, page.current + 2); %>
    <% if (start > 1) { %>
      <a href="<%- url_for('/') %>" class="page-num">1</a>
      <% if (start > 2) { %><span class="page-ellipsis">…</span><% } %>
    <% } %>
    <% for (var i = start; i <= end; i++) { %>
      <% var link = i === 1 ? '/' : '/page/' + i + '/'; %>
      <a href="<%- url_for(link) %>" class="page-num<%= i === page.current ? ' active' : '' %>"><%= i %></a>
    <% } %>
    <% if (end < page.total) { %>
      <% if (end < page.total - 1) { %><span class="page-ellipsis">…</span><% } %>
      <a href="<%- url_for('/page/' + page.total + '/') %>" class="page-num"><%= page.total %></a>
    <% } %>
  </div>

  <% if (page.next) { %>
    <a href="<%- url_for(page.next_link) %>" class="page-btn page-next" aria-label="下一页">
      下一页
      <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="9 18 15 12 9 6"/></svg>
    </a>
  <% } %>
</nav>
<% } %>
