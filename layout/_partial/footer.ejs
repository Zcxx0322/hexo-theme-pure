<footer class="site-footer">
  <div class="container footer-inner">
    <div class="footer-links">
      <% if (theme.social) { %>
        <% if (theme.social.github) { %>
          <a href="<%= theme.social.github %>" target="_blank" rel="noopener" aria-label="GitHub">
            <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="currentColor">
              <path d="M12 0C5.37 0 0 5.37 0 12c0 5.31 3.435 9.795 8.205 11.385.6.105.825-.255.825-.57 0-.285-.015-1.23-.015-2.235-3.015.555-3.795-.735-4.035-1.41-.135-.345-.72-1.41-1.23-1.695-.42-.225-1.02-.78-.015-.795.945-.015 1.62.87 1.845 1.23 1.08 1.815 2.805 1.305 3.495.99.105-.78.42-1.305.765-1.605-2.67-.3-5.46-1.335-5.46-5.925 0-1.305.465-2.385 1.23-3.225-.12-.3-.54-1.53.12-3.18 0 0 1.005-.315 3.3 1.23.96-.27 1.98-.405 3-.405s2.04.135 3 .405c2.295-1.56 3.3-1.23 3.3-1.23.66 1.65.24 2.88.12 3.18.765.84 1.23 1.905 1.23 3.225 0 4.605-2.805 5.625-5.475 5.925.435.375.81 1.095.81 2.22 0 1.605-.015 2.895-.015 3.3 0 .315.225.69.825.57A12.02 12.02 0 0 0 24 12c0-6.63-5.37-12-12-12z"/>
            </svg>
          </a>
        <% } %>
        <% if (theme.social.twitter) { %>
          <a href="<%= theme.social.twitter %>" target="_blank" rel="noopener" aria-label="Twitter/X">
            <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="currentColor">
              <path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"/>
            </svg>
          </a>
        <% } %>
        <% if (theme.social.email) { %>
          <a href="mailto:<%= theme.social.email %>" aria-label="Email">
            <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/><polyline points="22,6 12,13 2,6"/>
            </svg>
          </a>
        <% } %>
        <% if (theme.social.rss) { %>
          <a href="<%- url_for(theme.social.rss) %>" aria-label="RSS">
            <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <path d="M4 11a9 9 0 0 1 9 9"/><path d="M4 4a16 16 0 0 1 16 16"/><circle cx="5" cy="19" r="1"/>
            </svg>
          </a>
        <% } %>
      <% } %>
    </div>

    <div class="footer-info">
      <span>&copy; <%= theme.footer && theme.footer.since ? theme.footer.since + ' – ' : '' %><%= new Date().getFullYear() %> <%= config.author || config.title %></span>
      <span class="footer-sep">·</span>
      <span>Powered by <a href="https://hexo.io" target="_blank" rel="noopener">Hexo</a> &amp; <a href="https://github.com/Zcxx0322/hexo-theme-pure" target="_blank" rel="noopener">Pure</a></span>
      <% if (theme.footer && theme.footer.icp) { %>
        <span class="footer-sep">·</span>
        <a href="https://beian.miit.gov.cn/" target="_blank" rel="noopener"><%= theme.footer.icp %></a>
      <% } %>
    </div>

    <% if (theme.footer && theme.footer.last_updated !== false) { %>
      <% var latest = pure_last_updated(); %>
      <% if (latest) { %>
      <div class="footer-last-updated">
        <span>最后更新于 <%= latest.format('YYYY-MM-DD HH:mm') %></span>
      </div>
      <% } %>
    <% } %>

    <% if (theme.footer && theme.footer.custom_text) { %>
      <div class="footer-custom"><%- theme.footer.custom_text %></div>
    <% } %>
  </div>
</footer>
