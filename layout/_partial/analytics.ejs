<% if (theme.analytics) { %>
  <% if (theme.analytics.google && theme.analytics.google.enable && theme.analytics.google.id) { %>
    <script async src="https://www.googletagmanager.com/gtag/js?id=<%= theme.analytics.google.id %>"></script>
    <script>
      window.dataLayer=window.dataLayer||[];
      function gtag(){dataLayer.push(arguments);}
      gtag('js',new Date());
      gtag('config','<%= theme.analytics.google.id %>');
    </script>
  <% } %>
  <% if (theme.analytics.umami && theme.analytics.umami.enable && theme.analytics.umami.src) { %>
    <script async defer data-website-id="<%= theme.analytics.umami.website_id %>" src="<%= theme.analytics.umami.src %>"></script>
  <% } %>
  <% if (theme.analytics.baidu && theme.analytics.baidu.enable && theme.analytics.baidu.id) { %>
    <script>
      var _hmt=_hmt||[];
      (function(){var hm=document.createElement('script');hm.src='https://hm.baidu.com/hm.js?<%= theme.analytics.baidu.id %>';
      var s=document.getElementsByTagName('script')[0];s.parentNode.insertBefore(hm,s);})();
    </script>
  <% } %>
<% } %>
