<div class="archive-page">
  <h1 class="page-heading">归档
    <span class="page-heading-count"><%= site.posts.length %> 篇</span>
  </h1>

  <%
    // Group posts by year → month
    var archive = {};
    page.posts.each(function(post) {
      var y = post.date.year();
      var m = post.date.format('MM');
      if (!archive[y]) archive[y] = {};
      if (!archive[y][m]) archive[y][m] = [];
      archive[y][m].push(post);
    });

    var years = Object.keys(archive).sort(function(a, b) { return b - a; });
  %>

  <% years.forEach(function(y) { %>
    <div class="archive-year">
      <h2 class="archive-year-title"><%= y %></h2>
      <%
        var months = Object.keys(archive[y]).sort(function(a, b) { return b - a; });
      %>
      <% months.forEach(function(m) { %>
        <h3 class="archive-month-title"><%= parseInt(m, 10) %>月</h3>
        <ul class="archive-list">
          <% archive[y][m].forEach(function(post) { %>
            <li class="archive-item">
              <time class="archive-date"><%= post.date.format('DD') %></time>
              <a href="<%- url_for(post.path) %>" class="archive-title"><%= post.title %></a>
            </li>
          <% }); %>
        </ul>
      <% }); %>
    </div>
  <% }); %>
</div>
