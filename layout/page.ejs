<% if (page.type === 'tags') { %>

<div class="tags-page">
  <h1 class="page-heading">标签
    <span class="page-heading-count"><%= site.tags.length %> 个</span>
  </h1>
  <div class="tags-cloud">
    <% site.tags.sort('name').each(function(tag) { %>
      <a href="<%- url_for(tag.path) %>" class="tag-cloud-item" data-count="<%= tag.length %>">
        #<%= tag.name %>
        <span class="tag-count"><%= tag.length %></span>
      </a>
    <% }); %>
  </div>
</div>

<% } else if (page.type === 'categories') { %>

<div class="categories-page">
  <h1 class="page-heading">分类
    <span class="page-heading-count"><%= site.categories.length %> 个</span>
  </h1>
  <ul class="categories-list">
    <% site.categories.sort('name').each(function(cat) { %>
      <li class="category-item">
        <a href="<%- url_for(cat.path) %>" class="category-link">
          <span class="category-name"><%= cat.name %></span>
          <span class="category-count"><%= cat.length %></span>
        </a>
      </li>
    <% }); %>
  </ul>
</div>

<% } else { %>

<article class="page-article">
  <% if (page.title) { %>
    <header class="page-header">
      <h1 class="page-title"><%= page.title %></h1>
    </header>
  <% } %>
  <div class="post-content">
    <%- page.content %>
  </div>
  <%- partial('_partial/comments') %>
</article>

<% } %>
