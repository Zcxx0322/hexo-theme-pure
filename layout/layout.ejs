<!DOCTYPE html>
<html lang="<%= config.language || 'zh-CN' %>">
<head>
  <%- partial('_partial/head') %>
</head>
<body>
  <%- partial('_partial/header') %>

  <main class="main-content">
    <div class="container">
      <%- body %>
    </div>
  </main>

  <%- partial('_partial/footer') %>

  <% if (theme.search && theme.search.enable) { %>
    <%- partial('_partial/search-modal') %>
  <% } %>

  <button class="back-to-top" id="backToTop" aria-label="回到顶部" title="回到顶部">
    <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="18 15 12 9 6 15"></polyline></svg>
  </button>

  <script src="<%- url_for('/js/main.js') %>"></script>
  <% if (theme.search && theme.search.enable) { %>
    <script src="<%- url_for('/js/search.js') %>"></script>
  <% } %>

  <%- partial('_partial/analytics') %>
</body>
</html>
